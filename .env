# ============================================
# MemoirOS - Environment Configuration
# ============================================

# --------------------------------------------
# LLM Configuration (Local Ollama Only)
# --------------------------------------------
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:8b
LLM_TIMEOUT=120000

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434/api/chat

# --------------------------------------------
# Server Configuration
# --------------------------------------------
PORT=3000

# --------------------------------------------
# Storage Configuration
# --------------------------------------------
SQLITE_DB_PATH=data/memoiros.db

# --------------------------------------------
# Development
# --------------------------------------------
DEBUG=false
TEST_MODE=false
